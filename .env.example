# GitHub OAuth Credentials
# Create them at: https://github.com/settings/developers
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# NextAuth Configuration
# For production (Railway), this must be your public URL
# For local development: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Secret key for session encryption (generate a random string)
NEXTAUTH_SECRET=use_a_long_random_string_here
